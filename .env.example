# ─── Servidor ─────────────────────────────────────────────────────────────────
PORT=8082

# ─── Base de dados (PostgreSQL) ───────────────────────────────────────────────
SPRING_DATASOURCE_URL=jdbc:postgresql://localhost:5432/catalog_db
SPRING_DATASOURCE_USERNAME=ebooks
SPRING_DATASOURCE_PASSWORD=ebooks_secret

# ─── Elasticsearch (pesquisa de livros) ───────────────────────────────────────
SPRING_ELASTICSEARCH_URIS=http://localhost:9200

# ─── Redis (cache de livros) ──────────────────────────────────────────────────
SPRING_DATA_REDIS_URL=redis://localhost:6379

# ─── RabbitMQ ─────────────────────────────────────────────────────────────────
SPRING_RABBITMQ_HOST=localhost
SPRING_RABBITMQ_PORT=5672
SPRING_RABBITMQ_USERNAME=ebooks
SPRING_RABBITMQ_PASSWORD=ebooks_secret
SPRING_RABBITMQ_VIRTUAL_HOST=/

# ─── MinIO (armazenamento de capas) ──────────────────────────────────────────
MINIO_ENDPOINT=http://localhost:9000
MINIO_ACCESS_KEY=ebooks_admin
MINIO_SECRET_KEY=ebooks_secret_123
MINIO_BUCKET=ebooks-covers
